<section class="_contact _1">
  <div class="_content">
    <aside class="_i">
      <div class="_container full-1">
        <div class="_flex">
          <div class="_heading">
            <div class="in-heading">
              <div class="title-2">
                <h2 data-splitting>{{ section.settings.heading | escape }}</h2>
              </div>
              <div class="title-5">
                <h5 data-splitting>{{ section.settings.subtitle | escape }}</h5>
              </div>
            </div>
          </div>
          <div class="_boding">
            <div class="in-boding">
              <form method="post" action="/contact#contact_form" id="contact_form" accept-charset="UTF-8" class="_form-beans">
                <input type="hidden" name="form_type" value="contact">
                <input type="hidden" name="utf8" value="✓">
                <div class="form-floating">
                  <input type="text" name="contact[name]" id="floatingName" class="form-control text-3" placeholder="Fullname" required>
                  <label for="floatingName" class="text-3">Fullname</label>
                </div>
                <div class="form-floating">
                  <input type="email" name="contact[email]" id="floatingEmail" class="form-control text-3" placeholder="E-mail" required>
                  <label for="floatingEmail" class="text-3">E-mail</label>
                </div>
                <div class="form-floating">
                  <textarea name="contact[body]" rows="6" id="floatingMessage" class="form-control text-3" placeholder="Message" required></textarea>
                  <label for="floatingMessage" class="text-3">Message</label>
                </div>
                <button type="submit" class="_btn btn-i _green">
                  <span class="_info text-btn">Submit</span>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>

      <span class="funnies _1">
        <figure class="fun-ii _jumping">
          <img src="https://cdn.shopify.com/s/files/1/0619/3971/2098/files/hongo_orange_2.svg?v=1745254120">
        </figure>
        <figure class="fun-i _greeting">
          <div class="_message _1">
            <div class="_data">
              <span>Drop us a line!</span>
            </div>
            <img class="_bg" src="https://cdn.shopify.com/s/files/1/0619/3971/2098/files/message_white_1.svg?v=1745267567">
          </div>
          <img src="https://cdn.shopify.com/s/files/1/0619/3971/2098/files/hongo_orange_2.svg?v=1745254120">
        </figure>
      </span>

      <aside class="_crackers">
        {% for i in (1..10) %}
          <figure class="_crack _{{ i }}">
            <img src="https://cdn.shopify.com/s/files/1/0619/3971/2098/files/cracker.png?v=1745214096">
          </figure>
        {% endfor %}
      </aside>
    </aside>

    <aside class="_ii">
      <div class="_container full-1">
        <div class="_flex">
          <div class="_heading">
            <div class="in-heading">
              <div class="title-2">
                <h2 data-splitting>{{ section.settings.heading_wholesale | escape }}</h2>
              </div>
              <div class="title-5">
                <h5 data-splitting>{{ section.settings.subtitle_wholesale | escape }}</h5>
              </div>
              <br>
              <div class="info_email">
                <div class="title-5">
                  <h5>Email us:</h5>
                </div>
                <div class="title-4">
                  <h5><a href="mailto:{{ section.settings.email | escape }}" target="_blank">{{ section.settings.email | escape }}</a></h5>
                </div>
              </div>
            </div>
          </div>
          <div class="_boding">
            <div class="in-boding">
              <form method="post" action="/contact#contact_form" id="contact_form_wholesale" accept-charset="UTF-8" class="_form-beans">
                <input type="hidden" name="form_type" value="wholesale">
                <input type="hidden" name="utf8" value="✓">
                <div class="form-floating">
                  <input type="text" name="contact[name]" id="floatingNameWholesale" class="form-control text-3" placeholder="Fullname" required>
                  <label for="floatingNameWholesale" class="text-3">Fullname</label>
                </div>
                <div class="form-floating">
                  <input type="email" name="contact[email]" id="floatingEmailWholesale" class="form-control text-3" placeholder="E-mail" required>
                  <label for="floatingEmailWholesale" class="text-3">E-mail</label>
                </div>
                <div class="form-floating">
                  <textarea name="contact[body]" id="floatingMessageWholesale" class="form-control text-3" placeholder="Message" required></textarea>
                  <label for="floatingMessageWholesale" class="text-3">Message</label>
                </div>
                <button type="submit" class="_btn btn-i _green">
                  <span class="_info text-btn">Submit</span>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>

{% schema %}
{
  "name": "Contact",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Spill the Beans!"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Moosh and Lou would love to hear from you!"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How are we doing? How are you liking our crackers?"
    },
    {
      "type": "text",
      "id": "subtitle_wholesale",
      "label": "Subtitle for Wholesale",
      "default": "We're so honored you want Funhaven for your business! Please fill out the form on the right and we’ll get back to you within 2-3 business days."
    },
    {
      "type": "text",
      "id": "heading_wholesale",
      "label": "Heading for Wholesale",
      "default": "Want to carry us?"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "hello@funhavenfoods.com"
    }
  ],
  "presets": [
    {
      "name": "Contact",
      "category": "Custom"
    }
  ]
}
{% endschema %}
