<section class="_home _iv" style="background-color: {{ section.settings.background_color }};">
  <span id="about" class="_indicator"></span>
  <div class="_content">
    <div class="_inside _1">
      <div class="_container full-2">
        <div class="_heading">
          <div class="title-3">
            <h2><span data-splitting>{{ section.settings.subheading }}</span></h2>
          </div>
          <div class="title-2">
            <h2><span data-splitting>{{ section.settings.heading }}</span></h2>
          </div>
        </div>
        <div class="_boding">
          <table class="comparison-table">
            <thead>
              <tr>
                <th class="title-4">CATEGORY</th>
                <th class="title-4">FUNHAVEN</th>
                <th class="title-4">LEADING CRACKER BRANDS</th>
              </tr>
            </thead>
            <tbody>
              {% assign categories = 
                "Functional Flour,
                Use Olive Oil (instead of seed oils),
                OG Added Sugar,
                Cute cartoon mushroom mascots! :),
                Nut Free,
                No artificial flavors or corn syrup,
                Soy and Sesame Free,
                Gluten Free and Wheat Free,
                Vegan,
                Woman-Owned" | split: "," %}
              
              {% assign funhaven = "✔️,✔️,✔️,✔️,✔️,✔️,✔️,✔️,✔️,✔️" | split: "," %}
              {% assign leading = "❌,❌,❌,❌,❌,❌,❌,❌,very few,very few" | split: "," %}
              {% assign total = categories.size | minus: 1 %}
              {% for i in (0..total) %}
                <tr>
                  <td class="title-6">{{ categories[i] | strip }}</td>
                  <td class="title-6">
                    {% if funhaven[i] == "✔️" %}
                      <img src="https://cdn.shopify.com/s/files/1/0619/3971/2098/files/check-1.svg?v=1744741650" alt="Check" width="20" height="20">
                    {% else %}
                      {{ funhaven[i] }}
                    {% endif %}
                  </td>
                  <td class="title-6">
                    {% if leading[i] == "✔️" %}
                      <img src="https://cdn.shopify.com/s/files/1/0619/3971/2098/files/check-1.svg?v=1745451142" alt="Check" width="20" height="20">
                    {% elsif leading[i] == "❌" %}
                      <img src="https://cdn.shopify.com/s/files/1/0619/3971/2098/files/deny-1.svg?v=1745451236" alt="X" width="20" height="20">
                    {% else %}
                      {{ leading[i] }}
                    {% endif %}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>

        </div>
      </div>
    </div>
  </div>
  <div class="_inside">
    <div class="_pictures">
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home IV",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fff7eb"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Upgrade Your Everyday Snack!"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Us Versus Them"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Image 5"
    }
  ],
  "presets": [
    {
      "name": "Home IV",
      "category": "Custom"
    }
  ]
}
{% endschema %}
