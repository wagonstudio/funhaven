<section class="_faq _1">
  <div class="_content">
    <div class="_container full-3">
      <div class="_heading">
        <div class="title-2">
          <h2>{{ section.settings.heading | escape }}</h2>
        </div>
        <div class="title-3">
          <h3>{{ section.settings.subtitle | escape }}</h3>
        </div>
      </div>
      <div class="_boding">
        <div class="card-i _1">
          <aside class="_front">
            <div class="in-front">
              <div class="accordion" id="accordion_faq">
                {% for block in section.blocks %}
                  <div class="accordion-item">
                    <h2 class="accordion-header" id="heading-{{ block.id }}">
                      <button class="accordion-button {% unless forloop.first %}collapsed{% endunless %}" type="button"
                              data-bs-toggle="collapse"
                              data-bs-target="#collapse-{{ block.id }}"
                              aria-expanded="{{ forloop.first }}"
                              aria-controls="collapse-{{ block.id }}">
                        <span class="_data title-5">{{ block.settings.question }}</span>
                        <span class="_icon"><i class="bi bi-caret-down-fill"></i></span>
                      </button>
                    </h2>
                    <div id="collapse-{{ block.id }}"
                         class="accordion-collapse collapse {% if forloop.first %}show{% endif %}"
                         aria-labelledby="heading-{{ block.id }}"
                         data-bs-parent="#accordion_faq">
                      <div class="accordion-body">
                        <div class="text-m">{{ block.settings.answer }}</div>
                      </div>
                    </div>
                  </div>
                {% endfor %}
              </div>
              <div class="_note">
                <div class="title-5">
                  <h5>{{ section.settings.cta_heading }}</h5>
                </div>
                <div class="_actions">
                  <a href="{{ section.settings.cta_link }}" class="_btn btn-i _blue_1">
                    <span>{{ section.settings.cta_label }}</span>
                  </a>
                </div>
              </div>
            </div>
          </aside>
          <figure class="_bg"></figure>
        </div>
      </div>
    </div>
  </div>
  <figure class="_bg">
    <img src="https://cdn.shopify.com/s/files/1/0619/3971/2098/files/clouds_1.svg?v=1745210578">
  </figure>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "ARE WE HAVEN’ FUN YET?"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "Note Heading",
      "default": "Still have questions?"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Text",
      "default": "GET IN TOUCH WITH US"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We offer a 30-day return policy on all unopened packages.</p>"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "FAQ",
      "category": "Custom"
    }
  ]
}
{% endschema %}
